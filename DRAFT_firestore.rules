rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Doctor Collection Rules
    match /doctors/{doctorId} {
      function isValidDoctor(data) {
        return data.uid == doctorId &&
               data.name is string && data.name.size() < 100 &&
               data.specialization is string &&
               data.location is string &&
               data.available is bool;
      }
      
      allow read: if true; // Public listings
      allow create: if isSignedIn() && isOwner(doctorId) && isValidDoctor(incoming());
      allow update: if isSignedIn() && isOwner(doctorId) && isValidDoctor(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'specialization', 'location', 'consultationType', 'experience', 'available', 'profilePicUrl', 'bio', 'availableSlots'])
      );
    }

    // Patient Collection Rules
    match /patients/{patientId} {
      function isValidPatient(data) {
        return data.uid == patientId &&
               data.name is string &&
               data.email is string;
      }
      
      allow read: if isOwner(patientId);
      allow create, update: if isSignedIn() && isOwner(patientId) && isValidPatient(incoming());
    }

    // Appointment Rules
    match /appointments/{appointmentId} {
      function isValidAppointment(data) {
        return data.appointmentId == appointmentId &&
               data.doctorId is string &&
               data.patientId is string &&
               data.status in ['pending', 'confirmed', 'cancelled', 'completed'];
      }

      // Read: Both patient and doctor can read
      allow read: if isSignedIn() && (isOwner(resource.data.patientId) || isOwner(resource.data.doctorId));
      
      // Create: Only patient can create
      allow create: if isSignedIn() && isOwner(incoming().patientId) && isValidAppointment(incoming());
      
      // Update: Both can update status, but only owner can cancel their own
      allow update: if isSignedIn() && (isOwner(existing().patientId) || isOwner(existing().doctorId)) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
    }

    // Chat Rules
    match /chats/{chatId} {
      allow read: if isSignedIn() && (isOwner(resource.data.patientId) || isOwner(resource.data.doctorId));
      allow create: if isSignedIn() && (isOwner(incoming().patientId) || isOwner(incoming().doctorId));
      allow update: if isSignedIn() && (isOwner(existing().patientId) || isOwner(existing().doctorId)) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['messages'])
      );
    }
  }
}
