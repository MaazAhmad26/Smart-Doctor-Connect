{
  "entities": {
    "Doctor": {
      "title": "Doctor Profile",
      "description": "Information about a doctor including their specialization, location, and availability.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "location": { "type": "string" },
        "consultationType": { "type": "string", "enum": ["Online", "Physical", "Both"] },
        "experience": { "type": "string" },
        "rating": { "type": "number" },
        "available": { "type": "boolean" },
        "profilePicUrl": { "type": "string" },
        "bio": { "type": "string" },
        "availableSlots": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "specialization", "location", "available"]
    },
    "Patient": {
      "title": "Patient Profile",
      "description": "User profile for patients.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A booked medical consultation.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorName": { "type": "string" },
        "patientName": { "type": "string" },
        "specialization": { "type": "string" },
        "timeSlot": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["Online", "Physical"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["appointmentId", "doctorId", "patientId", "date", "timeSlot", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Direct communication between patient and doctor (or AI agent).",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientId": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "isAI": { "type": "boolean" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "doctors": {
      "schema": "Doctor",
      "description": "Collection of all available doctors."
    },
    "patients": {
      "schema": "Patient",
      "description": "Collection of patient profiles."
    },
    "appointments": {
      "schema": "Appointment",
      "description": "Collection of all appointments."
    },
    "chats": {
      "schema": "Chat",
      "description": "Real-time chat sessions."
    }
  }
}
